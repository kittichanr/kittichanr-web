---
import SocialList from "@/components/SocialList";
import PageLayout from "@/layouts/Base";
import { careerPath } from "@/utils";

const meta = {
	title: "Home",
	description: "Personal website of Kittichan Ruadrewworakit - Software Engineer from Thailand",
};
---

<PageLayout meta={meta}>
	<!-- HOME SECTION -->
	<section id="home" class="mb-16">
		<h1 class="title mb-6">👋 Hi there</h1>
		<p class="mb-4">
			I'm Kittichan you can call me <b>"Petch"</b>. I'm software engineer from Thailand 🇹🇭. 
			I'm passionate about creating efficient and scalable software solutions. I like to learn new technologies and improve my skills. I have experience in both frontend and backend development, and I'm always looking for new challenges and opportunities to grow.
		right now I currently learning about System Design, Distributed Systems, and AI-Powered Development.
		</p>
		
		<SocialList />
	</section>

	<!-- VISUAL DIVIDER -->
	<div class="mb-16 border-t-2 border-dashed border-accent/30"></div>

	<!-- CAREER PATH SECTION -->
	<section id="career" class="space-y-12">
		<!-- Career Path Section -->
		<div class="rounded-lg border-2 border-dashed border-accent/20 bg-accent/5 p-6 sm:p-8">
			<h2 class="title mb-8">Career Path</h2>
			<div class="relative space-y-8 border-l-2 border-dashed border-accent/30 pl-8">
				{
					careerPath.map((item) => {
						return (
							<div class="group relative">
								{/* Timeline dot */}
								<div class="absolute -left-[2.4rem] top-2 h-4 w-4 rounded-full border-2 border-accent bg-bgColor transition-all group-hover:scale-125 group-hover:border-accent group-hover:bg-accent" />

								{/* Content */}
								<div class="space-y-2">
									<div class="text-sm font-medium text-accent">{item.year}</div>
									<h3 class="text-lg font-semibold text-accent-2">{item.title}</h3>
									<div class="prose prose-sm text-textColor/80" set:html={item.description} />
								</div>
							</div>
						);
					})
				}
			</div>
		</div>

	</section>

	<!-- VISUAL DIVIDER -->
	<div class="mb-16 border-t-2 border-dashed border-accent/30"></div>

	<!-- TECH STACK SECTION -->
	<section id="tech-stack">
		<div class="rounded-lg border-2 border-dashed border-accent/20 bg-accent/5 p-6 sm:p-8">
			<h2 class="title mb-8">Tech Stack</h2>
			<div class="space-y-6">
				{/* Languages */}
				<div class="group space-y-3">
					<h3 class="flex items-center gap-2 text-base font-semibold text-accent-2">
						<span class="h-px w-4 bg-accent transition-all group-hover:w-8"></span>
						Languages
					</h3>
					<div class="flex flex-wrap gap-2 pl-6">
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">TypeScript</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">JavaScript</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Go</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Rust</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">HTML</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">CSS</span>
					</div>
				</div>

				{/* Frontend */}
				<div class="group space-y-3">
					<h3 class="flex items-center gap-2 text-base font-semibold text-accent-2">
						<span class="h-px w-4 bg-accent transition-all group-hover:w-8"></span>
						Frontend
					</h3>
					<div class="flex flex-wrap gap-2 pl-6">
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">React</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">React Native</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Next.js</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Redux</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Tailwind CSS</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Astro</span>
					</div>
				</div>

				{/* Backend */}
				<div class="group space-y-3">
					<h3 class="flex items-center gap-2 text-base font-semibold text-accent-2">
						<span class="h-px w-4 bg-accent transition-all group-hover:w-8"></span>
						Backend
					</h3>
					<div class="flex flex-wrap gap-2 pl-6">
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Node.js</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">NestJS</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Gin</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Actix</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">gRPC</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">REST API</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">GraphQL</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Microservices</span>
					</div>
				</div>

				{/* Databases & Messaging */}
				<div class="group space-y-3">
					<h3 class="flex items-center gap-2 text-base font-semibold text-accent-2">
						<span class="h-px w-4 bg-accent transition-all group-hover:w-8"></span>
						Databases & Messaging
					</h3>
					<div class="flex flex-wrap gap-2 pl-6">
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">PostgreSQL</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">MySQL</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Redis</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">MongoDB</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Elasticsearch</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Kafka</span>
					</div>
				</div>

				{/* DevOps & Tools */}
				<div class="group space-y-3">
					<h3 class="flex items-center gap-2 text-base font-semibold text-accent-2">
						<span class="h-px w-4 bg-accent transition-all group-hover:w-8"></span>
						DevOps & Tools
					</h3>
					<div class="flex flex-wrap gap-2 pl-6">
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Git</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Docker</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Kubernetes</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">CI/CD</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Grafana</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Kibana</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Jest</span>
					</div>
				</div>

				{/* AI Tools */}
				<div class="group space-y-3">
					<h3 class="flex items-center gap-2 text-base font-semibold text-accent-2">
						<span class="h-px w-4 bg-accent transition-all group-hover:w-8"></span>
						AI-Powered Development
					</h3>
					<div class="flex flex-wrap gap-2 pl-6">
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Claude Code</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Cursor</span>
						<span class="rounded border border-accent/30 bg-bgColor px-3 py-1.5 text-sm font-medium transition-all hover:border-accent hover:bg-accent/10">Windsurf</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- VISUAL DIVIDER -->
	<div class="mb-16 border-t-2 border-dashed border-accent/30"></div>

	<!-- BLOG SECTION -->
	<section id="blog" class="space-y-6">
		<h2 class="title mb-4">Blog</h2>
		<p class="mb-6">
			I write about software engineering, web development, and my learning journey.
			Check out my articles on:
		</p>
		<div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
			<a
				href="https://dev.to/kittichanr"
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border-2 border-accent/20 bg-accent/5 px-6 py-4 transition-all hover:border-accent/40 hover:bg-accent/10"
			>
				<svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
					<path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-.72.04-.75.03v1.77l1.22.03 1.2.04v1.28h-1.6c-1.53 0-1.6-.01-1.87-.3l-.3-.28v-3.16c0-3.02.01-3.18.25-3.48.23-.31.25-.31 1.88-.31h1.64v1.3zm4.68 5.45c-.17.43-.64.79-1 .79-.18 0-.45-.15-.67-.39-.32-.32-.45-.63-.82-2.08l-.9-3.39-.45-1.67h.76c.4 0 .75.02.75.05 0 .06 1.16 4.54 1.26 4.83.04.15.32-.7.73-2.3l.66-2.52.74-.04c.4-.02.73 0 .73.04 0 .14-1.67 6.38-1.8 6.68z"/>
				</svg>
				<div class="flex flex-col">
					<span class="font-semibold">DEV Community</span>
					<span class="text-sm opacity-70">@kittichanr</span>
				</div>
			</a>

			<a
				href="https://medium.com/@kittichanr"
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border-2 border-accent/20 bg-accent/5 px-6 py-4 transition-all hover:border-accent/40 hover:bg-accent/10"
			>
				<svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
					<path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
				</svg>
				<div class="flex flex-col">
					<span class="font-semibold">Medium</span>
					<span class="text-sm opacity-70">@kittichanr</span>
				</div>
			</a>
		</div>
	</section>
</PageLayout>
